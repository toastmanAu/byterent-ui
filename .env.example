# ByteRent UI environment variables (Vite only exposes VITE_*-prefixed vars
# to client code). Copy to .env.local for a dev run, .env.production for
# Cloudflare Pages builds.

# Where the byterent-indexer HTTP server is reachable.
#   dev:  http://localhost:8117 (default; leave unset)
#   prod: https://api.byterent.xyz (or wherever the indexer is hosted)
VITE_INDEXER_URL=http://localhost:8117
