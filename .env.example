# ByteRent UI environment variables.
# Vite only exposes VITE_*-prefixed vars to client code. Copy this file
# to .env.local for a dev override, or .env.production for a Cloudflare
# Pages build. Both are gitignored.

# Override the JoyID auth/sign relay Worker URL. Defaults to the shared
# production instance; set this if you're running your own relay or
# pointing at a .workers.dev preview deploy.
# VITE_AUTH_WORKER_URL=https://auth.byterent.xyz

# Override the public URL served to JoyID as the dApp icon. JoyID fetches
# this image from its own server during the auth screen, so it must be
# publicly reachable HTTPS. Defaults to the auth Worker's /logo.png.
# VITE_APP_ICON_URL=https://auth.byterent.xyz/logo.png
